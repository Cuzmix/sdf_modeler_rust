build ./skshaper.lib: alink obj/modules/skshaper/src/skshaper.SkShaper.obj obj/modules/skshaper/src/skshaper.SkShaper_factory.obj obj/modules/skshaper/src/skshaper.SkShaper_primitive.obj || ./skia.lib
