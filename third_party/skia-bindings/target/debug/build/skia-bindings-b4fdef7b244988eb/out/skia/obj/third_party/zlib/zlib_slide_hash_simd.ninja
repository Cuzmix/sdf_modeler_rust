defines = -D_CRT_SECURE_NO_WARNINGS -D_HAS_EXCEPTIONS=0 -DWIN32_LEAN_AND_MEAN -DNOMINMAX -DNDEBUG -DZLIB_IMPLEMENTATION -DDEFLATE_SLIDE_HASH_SSE2
include_dirs =
label_name = zlib_slide_hash_simd
root_out_dir = .
target_out_dir = obj/third_party/zlib
target_output_name = zlib_slide_hash_simd


build obj/third_party/zlib/zlib_slide_hash_simd.stamp: stamp || obj/third_party/zlib/zlib_common_headers.stamp
