rule copy
  command = cmd.exe /c  python "C:/Users/Manny/Documents/Code Projects/Typscript/sdf_modeler_rust/.tools/skia/gn/cp.py" ${in} ${out}
  description = copy ${in} ${out}
rule stamp
  command = cmd.exe /c  echo > ${out}
  description = stamp ${out}
rule cc
  command =  "C:\Users\Manny\Documents\Code Projects\Typscript\sdf_modeler_rust\.tools\llvm/bin/clang-cl.exe" /nologo /showIncludes /FC ${defines} ${include_dirs} ${cflags}  ${cflags_c} /c ${in} /Fo${out} /Fd"${target_out_dir}/${label_name}_c.pdb"
  description = compile ${in}
  deps = msvc
rule cxx
  command =  "C:\Users\Manny\Documents\Code Projects\Typscript\sdf_modeler_rust\.tools\llvm/bin/clang-cl.exe" /nologo /showIncludes /FC ${defines} ${include_dirs} ${cflags}  ${cflags_cc} /c ${in} /Fo${out} /Fd"${target_out_dir}/${label_name}_c.pdb"
  description = compile ${in}
  deps = msvc
rule asm
  command = "C:\Program Files (x86)\Microsoft Visual Studio\2019\BuildTools\VC/Tools/MSVC/14.29.30133/bin/HostX64/x64/ml64.exe" ${asmflags} /nologo /c /Fo ${out} ${in}
  description = assemble ${in}
rule alink
  command = "C:\Users\Manny\Documents\Code Projects\Typscript\sdf_modeler_rust\.tools\llvm/bin/lld-link.exe" /lib /nologo /ignore:4221 ${arflags} /OUT:${out} @${out}.rsp
  description = link ${out}
  rspfile = ${out}.rsp
  rspfile_content = ${in_newline}
rule solink
  command = "C:\Users\Manny\Documents\Code Projects\Typscript\sdf_modeler_rust\.tools\llvm/bin/lld-link.exe" /nologo /IMPLIB:${output_dir}/${target_output_name}${output_extension}.lib /DLL /OUT:${output_dir}/${target_output_name}${output_extension} /PDB:${output_dir}/${target_output_name}${output_extension}.pdb @${output_dir}/${target_output_name}${output_extension}.rsp
  description = link ${out}
  rspfile = ${output_dir}/${target_output_name}${output_extension}.rsp
  rspfile_content = ${in_newline} ${libs} ${solibs} ${ldflags}
  restat = 1
rule link
  command = "C:\Users\Manny\Documents\Code Projects\Typscript\sdf_modeler_rust\.tools\llvm/bin/lld-link.exe" /nologo /OUT:${root_out_dir}/${target_output_name}${output_extension} /PDB:${root_out_dir}/${target_output_name}${output_extension}.pdb @${root_out_dir}/${target_output_name}${output_extension}.rsp
  description = link ${out}
  rspfile = ${root_out_dir}/${target_output_name}${output_extension}.rsp
  rspfile_content = ${in_newline} ${libs} ${solibs} ${ldflags}

