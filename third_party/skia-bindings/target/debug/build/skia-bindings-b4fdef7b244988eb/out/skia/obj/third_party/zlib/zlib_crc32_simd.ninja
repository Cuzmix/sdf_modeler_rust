defines = -D_CRT_SECURE_NO_WARNINGS -D_HAS_EXCEPTIONS=0 -DWIN32_LEAN_AND_MEAN -DNOMINMAX -DNDEBUG -DZLIB_IMPLEMENTATION -DCRC32_SIMD_SSE42_PCLMUL
include_dirs =
cflags = -msse4.2 -mpclmul -Wno-attributes /bigobj /utf-8 -imsvc "C$:\Program$ Files$ (x86)\Microsoft$ Visual$ Studio\2019\BuildTools\VC/Tools/MSVC/14.29.30133/include" -imsvc "C$:/Program$ Files$ (x86)/Windows$ Kits/10/Include/10.0.22621.0/shared" -imsvc "C$:/Program$ Files$ (x86)/Windows$ Kits/10/Include/10.0.22621.0/ucrt" -imsvc "C$:/Program$ Files$ (x86)/Windows$ Kits/10/Include/10.0.22621.0/um" -imsvc "C$:/Program$ Files$ (x86)/Windows$ Kits/10/Include/10.0.22621.0/winrt" /O2 /Zc$:inline /MD -D__RTMINTRIN_H --target=x86_64-pc-windows-msvc
cflags_c =
label_name = zlib_crc32_simd
root_out_dir = .
target_out_dir = obj/third_party/zlib
target_output_name = zlib_crc32_simd

build obj/third_party/externals/zlib/zlib_crc32_simd.crc32_simd.obj: cc ../../../../../../../../.tools/skia/third_party/externals/zlib/crc32_simd.c
  source_file_part = crc32_simd.c
  source_name_part = crc32_simd
build obj/third_party/externals/zlib/zlib_crc32_simd.crc_folding.obj: cc ../../../../../../../../.tools/skia/third_party/externals/zlib/crc_folding.c
  source_file_part = crc_folding.c
  source_name_part = crc_folding

build obj/third_party/zlib/zlib_crc32_simd.stamp: stamp obj/third_party/externals/zlib/zlib_crc32_simd.crc32_simd.obj obj/third_party/externals/zlib/zlib_crc32_simd.crc_folding.obj || obj/third_party/zlib/zlib_common_headers.stamp
