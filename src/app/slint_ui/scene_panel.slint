import { Button, HorizontalBox, LineEdit, ScrollView, VerticalBox } from "std-widgets.slint";
import { AppTheme } from "theme.slint";
import { ScenePanelState, SceneRowAction, SceneRowView, SceneTextAction, SceneToolbarAction } from "view_models.slint";

component SceneRowItem inherits Rectangle {
    in property <SceneRowView> scene_row;
    in property <int> row_index;

    callback perform_row_action(action: SceneRowAction, index: int);
    callback perform_text_action(action: SceneTextAction, text: string);

    height: scene_row.renaming ? 58px : 30px;
    background: scene_row.drop_target ? AppTheme.selected_row_background
        : scene_row.selected ? AppTheme.selected_row_background
        : transparent;

    VerticalBox {
        spacing: 2px;

        HorizontalBox {
            spacing: AppTheme.section_spacing;

            Rectangle { width: scene_row.depth * 14px; }
            Button {
                text: scene_row.has_children ? (scene_row.expanded ? "v" : ">") : " ";
                enabled: scene_row.has_children;
                clicked => { root.perform_row_action(SceneRowAction.toggle-row-expanded, root.row_index); }
            }
            Rectangle {
                min-width: 120px;
                horizontal-stretch: 1;
                Text {
                    text: scene_row.kind_label + " " + scene_row.label;
                    color: scene_row.locked ? #c8a77a : #ffffff;
                }
                TouchArea {
                    width: parent.width;
                    height: parent.height;
                    pointer-event(event) => {
                        if (event.kind == PointerEventKind.down && event.button == PointerEventButton.left) {
                            root.perform_row_action(
                                event.modifiers.control ? SceneRowAction.toggle-row-selection : SceneRowAction.select-row,
                                root.row_index
                            );
                        }
                    }
                }
            }
            Button { text: scene_row.hidden ? "Show" : "Hide"; clicked => { root.perform_row_action(SceneRowAction.toggle-row-visibility, root.row_index); } }
            Button { text: scene_row.locked ? "Unlock" : "Lock"; clicked => { root.perform_row_action(SceneRowAction.toggle-row-lock, root.row_index); } }
            Button { text: "Rename"; clicked => { root.perform_row_action(SceneRowAction.begin-row-rename, root.row_index); } }
            Button { text: scene_row.dragging ? "Dragging" : "Drag"; clicked => { root.perform_row_action(SceneRowAction.begin-row-drag, root.row_index); } }
            if scene_row.drop_allowed && !scene_row.dragging : Button {
                text: scene_row.drop_target ? "Drop*" : "Drop";
                clicked => { root.perform_row_action(SceneRowAction.drop-on-row, root.row_index); }
            }
            Button { text: "Dup"; clicked => { root.perform_row_action(SceneRowAction.duplicate-row, root.row_index); } }
            Button { text: "Del"; clicked => { root.perform_row_action(SceneRowAction.delete-row, root.row_index); } }
        }

        if scene_row.renaming : HorizontalBox {
            spacing: AppTheme.section_spacing;
            Rectangle { width: scene_row.depth * 14px + 24px; }
            rename_input := LineEdit {
                text: scene_row.rename_value;
                placeholder-text: "Rename object";
                edited(value) => { root.perform_text_action(SceneTextAction.update-rename-buffer, value); }
                accepted => { root.perform_text_action(SceneTextAction.rename-selected, self.text); }
            }
            Button { text: "Apply"; clicked => { root.perform_text_action(SceneTextAction.rename-selected, rename_input.text); } }
            Button { text: "Cancel"; clicked => { root.perform_text_action(SceneTextAction.cancel-rename, ""); } }
        }
    }
}

export component ScenePanel inherits Rectangle {
    in property <ScenePanelState> state;

    callback toolbar_action(action: SceneToolbarAction);
    callback row_action(action: SceneRowAction, index: int);
    callback text_action(action: SceneTextAction, text: string);

    width: 340px;
    background: AppTheme.panel_background;

    ScrollView {
        width: parent.width;
        height: parent.height;

        VerticalBox {
            spacing: AppTheme.section_spacing;

            Text { text: "Scene"; }
            Text { text: root.state.selection_summary; wrap: word-wrap; }
            if root.state.drag_summary != "" : Text { text: root.state.drag_summary; wrap: word-wrap; }

            HorizontalBox {
                spacing: AppTheme.section_spacing;
                Button { text: "Sphere"; clicked => { root.toolbar_action(SceneToolbarAction.create-sphere); } }
                Button { text: "Box"; clicked => { root.toolbar_action(SceneToolbarAction.create-box); } }
                Button { text: "Light"; clicked => { root.toolbar_action(SceneToolbarAction.create-light); } }
            }

            HorizontalBox {
                spacing: AppTheme.section_spacing;
                Button { text: "Dup Sel"; clicked => { root.toolbar_action(SceneToolbarAction.duplicate-selected); } }
                Button { text: "Del Sel"; clicked => { root.toolbar_action(SceneToolbarAction.delete-selected); } }
                Button { text: "Rename"; clicked => { root.toolbar_action(SceneToolbarAction.start-rename-selected); } }
            }

            HorizontalBox {
                spacing: AppTheme.section_spacing;
                Button { text: "Node WS"; clicked => { root.toolbar_action(SceneToolbarAction.open-node-workspace); } }
                Button { text: "Light WS"; clicked => { root.toolbar_action(SceneToolbarAction.open-light-workspace); } }
                Button { text: "Cancel Drag"; clicked => { root.toolbar_action(SceneToolbarAction.cancel-row-drag); } }
            }

            LineEdit {
                text: root.state.scene_filter;
                placeholder-text: "Filter scene";
                edited(value) => { root.text_action(SceneTextAction.filter-scene, value); }
            }

            for row[index] in root.state.scene_rows : SceneRowItem {
                scene_row: row;
                row_index: index;
                perform_row_action(action, index) => { root.row_action(action, index); }
                perform_text_action(action, text) => { root.text_action(action, text); }
            }
        }
    }
}
