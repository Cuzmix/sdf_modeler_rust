import { Button, HorizontalBox, LineEdit, ScrollView, VerticalBox } from "std-widgets.slint";
import { HistoryRowView, SceneAction, SceneRowView } from "view_models.slint";
import { AppTheme } from "theme.slint";

component SceneRowItem inherits Rectangle {
    in property <SceneRowView> scene_row;
    in property <int> row_index;

    callback perform_action(action: SceneAction, index: int, text: string);

    height: 28px;
    background: scene_row.selected ? AppTheme.selected_row_background : transparent;

    HorizontalBox {
        spacing: AppTheme.section_spacing;

        Button { text: scene_row.hidden ? "Show" : "Hide"; clicked => { root.perform_action(SceneAction.toggle-row-visibility, root.row_index, ""); } }
        Button { text: scene_row.locked ? "Unlock" : "Lock"; clicked => { root.perform_action(SceneAction.toggle-row-lock, root.row_index, ""); } }
        Button { text: "+"; clicked => { root.perform_action(SceneAction.toggle-row-selection, root.row_index, ""); } }
        Button { text: scene_row.label; clicked => { root.perform_action(SceneAction.select-row, root.row_index, ""); } }
        Button { text: "Dup"; clicked => { root.perform_action(SceneAction.duplicate-row, root.row_index, ""); } }
        Button { text: "Del"; clicked => { root.perform_action(SceneAction.delete-row, root.row_index, ""); } }
    }
}

export component ScenePanel inherits Rectangle {
    in property <string> selection_summary;
    in property <string> selected_name;
    in-out property <string> scene_filter;
    in property <[SceneRowView]> scene_rows;
    in property <[HistoryRowView]> history_rows;

    callback perform_action(action: SceneAction, index: int, text: string);

    width: 300px;
    background: AppTheme.panel_background;

    ScrollView {
        width: parent.width;
        height: parent.height;

        VerticalBox {
            spacing: AppTheme.section_spacing;

            Text { text: "Scene"; }
            Text { text: root.selection_summary; }

            HorizontalBox {
                spacing: AppTheme.section_spacing;
                Button { text: "Sphere"; clicked => { root.perform_action(SceneAction.create-sphere, -1, ""); } }
                Button { text: "Box"; clicked => { root.perform_action(SceneAction.create-box, -1, ""); } }
                Button { text: "Light"; clicked => { root.perform_action(SceneAction.create-light, -1, ""); } }
            }

            HorizontalBox {
                spacing: AppTheme.section_spacing;
                Button { text: "Dup Sel"; clicked => { root.perform_action(SceneAction.duplicate-selected, -1, ""); } }
                Button { text: "Del Sel"; clicked => { root.perform_action(SceneAction.delete-selected, -1, ""); } }
            }

            LineEdit {
                text: root.selected_name;
                placeholder-text: "Rename selection";
                accepted => { root.perform_action(SceneAction.rename-selected, -1, self.text); }
            }

            LineEdit {
                text: root.scene_filter;
                placeholder-text: "Filter scene";
                edited(value) => { root.perform_action(SceneAction.filter-scene, -1, value); }
            }

            for row[index] in root.scene_rows : SceneRowItem {
                scene_row: row;
                row_index: index;
                perform_action(action, index, text) => { root.perform_action(action, index, text); }
            }

            Text { text: "History"; }

            for history in root.history_rows : Text {
                text: (history.is_undo ? "Undo: " : "Redo: ") + history.label;
            }
        }
    }
}
