import { Button, HorizontalBox, Slider, VerticalBox } from "std-widgets.slint";
import { AppTheme } from "theme.slint";
import { ReferenceImageAction, ReferenceRowView } from "view_models.slint";

export component ReferenceImagesPanel inherits VerticalBox {
    in property <string> summary;
    in property <[ReferenceRowView]> reference_rows;

    callback perform_reference_action(action: ReferenceImageAction, index: int, value: float);

    spacing: AppTheme.section_spacing;

    Text { text: "Reference Images"; }
    Text { text: root.summary; }

    for reference[index] in root.reference_rows : VerticalBox {
        spacing: 2px;

        Text { text: reference.label + " • " + reference.plane_label; wrap: word-wrap; }
        Text { text: reference.status_label; }

        HorizontalBox {
            spacing: AppTheme.section_spacing;
            Button { text: reference.visible ? "Hide" : "Show"; clicked => { root.perform_reference_action(ReferenceImageAction.toggle-reference-visibility, index, 0); } }
            Button { text: reference.locked ? "Unlock" : "Lock"; clicked => { root.perform_reference_action(ReferenceImageAction.toggle-reference-lock, index, 0); } }
            Button { text: "Cycle Plane"; clicked => { root.perform_reference_action(ReferenceImageAction.cycle-reference-plane, index, 0); } }
            Button { text: "Remove"; clicked => { root.perform_reference_action(ReferenceImageAction.remove-reference-image, index, 0); } }
        }

        Text { text: "Opacity " + reference.opacity; }
        Slider {
            minimum: 0;
            maximum: 1;
            step: 0.01;
            value: reference.opacity;
            changed(value) => { root.perform_reference_action(ReferenceImageAction.set-reference-opacity, index, value); }
        }

        Text { text: "Scale " + reference.scale; }
        Slider {
            minimum: 0.05;
            maximum: 20;
            step: 0.05;
            value: reference.scale;
            changed(value) => { root.perform_reference_action(ReferenceImageAction.set-reference-scale, index, value); }
        }
    }
}
