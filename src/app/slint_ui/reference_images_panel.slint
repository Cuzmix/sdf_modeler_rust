import { Button, HorizontalBox, Slider, VerticalBox } from "std-widgets.slint";
import { ReferenceRowView, UtilityAction } from "view_models.slint";
import { AppTheme } from "theme.slint";

export component ReferenceImagesPanel inherits VerticalBox {
    in property <[ReferenceRowView]> reference_rows;

    callback perform_action(action: UtilityAction, index: int, value: float);

    spacing: AppTheme.section_spacing;

    Text { text: "Reference Images"; }

    for reference[index] in root.reference_rows : HorizontalBox {
        spacing: AppTheme.section_spacing;

        VerticalBox {
            spacing: 2px;

            HorizontalBox {
                spacing: AppTheme.section_spacing;
                Button { text: reference.visible ? "Hide" : "Show"; clicked => { root.perform_action(UtilityAction.toggle-reference-visibility, index, 0); } }
                Button { text: reference.locked ? "Unlock" : "Lock"; clicked => { root.perform_action(UtilityAction.toggle-reference-lock, index, 0); } }
                Button { text: reference.plane_label; clicked => { root.perform_action(UtilityAction.cycle-reference-plane, index, 0); } }
                Text { text: reference.label; }
                Button { text: "Remove"; clicked => { root.perform_action(UtilityAction.remove-reference-image, index, 0); } }
            }

            HorizontalBox {
                spacing: AppTheme.section_spacing;
                Text { text: "Opacity " + reference.opacity; }
                Slider {
                    minimum: 0;
                    maximum: 1;
                    step: 0.01;
                    value: reference.opacity;
                    changed(value) => { root.perform_action(UtilityAction.set-reference-opacity, index, value); }
                }
            }

            HorizontalBox {
                spacing: AppTheme.section_spacing;
                Text { text: "Scale " + reference.scale; }
                Slider {
                    minimum: 0.05;
                    maximum: 20;
                    step: 0.05;
                    value: reference.scale;
                    changed(value) => { root.perform_action(UtilityAction.set-reference-scale, index, value); }
                }
            }
        }
    }
}
