}

export enum InspectorEditMode {
    nudge,
    set,
    toggle,
}

export enum RenderSettingsAction {
    set-show-grid,
    set-show-node-labels,
    set-show-bounding-box,
    set-show-light-gizmos,
    set-shadows-enabled,
    set-ao-enabled,
