import {
    ViewportDoubleClickAction,
    ViewportPathView,
    ViewportPointerAction,
    ViewportPointerButton,
    ViewportPointerPhase,
    ViewportScrollAction,
} from "view_models.slint";
import { AppTheme } from "theme.slint";

export component ViewportPanel inherits Rectangle {
    in property <image> viewport_image;
    in property <float> viewport_gizmo_viewbox_width;
    in property <float> viewport_gizmo_viewbox_height;
    in property <[ViewportPathView]> viewport_gizmo_paths;

    out property <float> viewport_width: viewport_frame.width / 1px;
    out property <float> viewport_height: viewport_frame.height / 1px;

    callback viewport_pointer_action(action: ViewportPointerAction);
    callback viewport_scroll_action(action: ViewportScrollAction);
    callback viewport_double_click(action: ViewportDoubleClickAction);

    background: AppTheme.viewport_background;
    horizontal-stretch: 1;
    vertical-stretch: 1;

    viewport_frame := Image {
        width: parent.width;
        height: parent.height;
        source: root.viewport_image;
        image-fit: fill;
    }

    for path in root.viewport_gizmo_paths: Path {
        width: parent.width;
        height: parent.height;
        viewbox-width: root.viewport_gizmo_viewbox_width;
        viewbox-height: root.viewport_gizmo_viewbox_height;
        commands: path.commands;
        stroke: path.stroke;
        fill: path.fill;
        stroke-width: path.stroke_width * 1px;
        stroke-line-cap: round;
        stroke-line-join: round;
    }

    TouchArea {
        width: parent.width;
        height: parent.height;

        pointer-event(event) => {
            root.viewport_pointer_action({
                phase: event.kind == PointerEventKind.down ? ViewportPointerPhase.down : event.kind == PointerEventKind.up ? ViewportPointerPhase.up : event.kind == PointerEventKind.cancel ? ViewportPointerPhase.cancel : ViewportPointerPhase.move,
                button: event.button == PointerEventButton.left ? ViewportPointerButton.primary : event.button == PointerEventButton.right ? ViewportPointerButton.secondary : event.button == PointerEventButton.middle ? ViewportPointerButton.middle : ViewportPointerButton.other,
                x: self.mouse_x / 1px,
                y: self.mouse_y / 1px,
                modifiers: {
                    ctrl: event.modifiers.control,
                    shift: event.modifiers.shift,
                    alt: event.modifiers.alt,
                },
                is_touch: false,
            });
        }

        scroll-event(event) => {
            root.viewport_scroll_action({
                delta_x: event.delta_x / 1px,
                delta_y: event.delta_y / 1px,
                modifiers: {
                    ctrl: event.modifiers.control,
                    shift: event.modifiers.shift,
                    alt: event.modifiers.alt,
                },
            });
            accept
        }

        double-clicked => {
            root.viewport_double_click({
                x: self.mouse_x / 1px,
                y: self.mouse_y / 1px,
            });
        }
    }
}
