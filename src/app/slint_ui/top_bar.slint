import { Button, HorizontalBox } from "std-widgets.slint";
import { AppTheme } from "theme.slint";
import { TopBarAction, TopBarState } from "view_models.slint";

export component TopBar inherits HorizontalBox {
    in property <TopBarState> state;

    callback perform_action(action: TopBarAction);

    spacing: AppTheme.frame_spacing;

    Button { text: "New"; clicked => { root.perform_action(TopBarAction.new-scene); } }
    Button { text: "Open"; clicked => { root.perform_action(TopBarAction.open-project); } }
    Button { text: "Save"; clicked => { root.perform_action(TopBarAction.save-project); } }
    Button { text: "Import"; clicked => { root.perform_action(TopBarAction.import-mesh); } }
    Button { text: "Export"; clicked => { root.perform_action(TopBarAction.export-mesh); } }
    Button { text: "Shot"; clicked => { root.perform_action(TopBarAction.take-screenshot); } }
    Button { text: "Add Ref"; clicked => { root.perform_action(TopBarAction.add-reference-image); } }
    Button { text: "Toggle Refs"; clicked => { root.perform_action(TopBarAction.toggle-all-reference-images); } }
    Button { text: "Frame"; clicked => { root.perform_action(TopBarAction.frame-all); } }
    Button { text: "Focus"; clicked => { root.perform_action(TopBarAction.focus-selected); } }
    Button { text: "Undo"; clicked => { root.perform_action(TopBarAction.undo); } }
    Button { text: "Redo"; clicked => { root.perform_action(TopBarAction.redo); } }
    Button { text: root.state.gizmo_translate_active ? "Move*" : "Move"; clicked => { root.perform_action(TopBarAction.set-gizmo-translate); } }
    Button { text: root.state.gizmo_rotate_active ? "Rotate*" : "Rotate"; clicked => { root.perform_action(TopBarAction.set-gizmo-rotate); } }
    Button { text: root.state.gizmo_scale_active ? "Scale*" : "Scale"; clicked => { root.perform_action(TopBarAction.set-gizmo-scale); } }
    Button { text: root.state.gizmo_local_space ? "Local" : "World"; clicked => { root.perform_action(TopBarAction.toggle-gizmo-space); } }
    Button { text: root.state.camera_is_ortho ? "Ortho" : "Persp"; clicked => { root.perform_action(TopBarAction.toggle-ortho); } }
    Button { text: root.state.measurement_mode_active ? "Measure*" : "Measure"; clicked => { root.perform_action(TopBarAction.toggle-measurement); } }
    Button { text: root.state.turntable_active ? "Turntable*" : "Turntable"; clicked => { root.perform_action(TopBarAction.toggle-turntable); } }
    Button { text: "Front"; clicked => { root.perform_action(TopBarAction.camera-front); } }
    Button { text: "Top"; clicked => { root.perform_action(TopBarAction.camera-top); } }
    Button { text: "Right"; clicked => { root.perform_action(TopBarAction.camera-right); } }

    Text { text: root.state.viewport_status; }
    Text { text: root.state.toast_text; }
    Text { text: root.state.task_status; }
}
