import { ScrollView, VerticalBox } from "std-widgets.slint";
import { InspectorEditKind, InspectorEditMode, InspectorPanelState, UtilityAction, UtilityPanelState } from "view_models.slint";
import { AppTheme } from "theme.slint";
import { ImportDialogPanel } from "import_dialog_panel.slint";
import { InspectorPanel } from "inspector_panel.slint";
import { ReferenceImagesPanel } from "reference_images_panel.slint";
import { RenderSettingsPanel } from "render_settings_panel.slint";

export component RightSidebar inherits Rectangle {
    in property <InspectorPanelState> inspector_state;
    in property <UtilityPanelState> utility_state;

    callback edit_inspector(kind: InspectorEditKind, mode: InspectorEditMode, axis: int, value: float);
    callback perform_utility_action(action: UtilityAction, index: int, value: float);

    width: 360px;
    background: AppTheme.panel_background;

    ScrollView {
        width: parent.width;
        height: parent.height;

        VerticalBox {
            spacing: AppTheme.section_spacing;

            InspectorPanel {
                state: root.inspector_state;
                edit_inspector(kind, mode, axis, value) => { root.edit_inspector(kind, mode, axis, value); }
            }

            ReferenceImagesPanel {
                reference_rows: root.utility_state.reference_rows;
                perform_action(action, index, value) => { root.perform_utility_action(action, index, value); }
            }

            RenderSettingsPanel {
                state: root.utility_state.render_settings;
                perform_action(action, index, value) => { root.perform_utility_action(action, index, value); }
            }

            ImportDialogPanel {
                state: root.utility_state.import_dialog;
                perform_action(action, index, value) => { root.perform_utility_action(action, index, value); }
            }
        }
    }
}
