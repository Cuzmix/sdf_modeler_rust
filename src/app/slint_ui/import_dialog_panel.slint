import { Button, HorizontalBox, SpinBox, VerticalBox } from "std-widgets.slint";
import { AppTheme } from "theme.slint";
import { ImportDialogAction, ImportDialogState } from "view_models.slint";

export component ImportDialogPanel inherits VerticalBox {
    in property <ImportDialogState> state;

    callback perform_import_action(action: ImportDialogAction, value: float);

    spacing: AppTheme.section_spacing;

    if root.state.visible : VerticalBox {
        spacing: AppTheme.section_spacing;
        Text { text: "Import Mesh"; }
        Text { text: root.state.summary; wrap: word-wrap; }
        SpinBox { minimum: 8; maximum: 512; step-size: 8; value: root.state.resolution; edited => { root.perform_import_action(ImportDialogAction.set-import-resolution, self.value); } }
        HorizontalBox {
            spacing: AppTheme.section_spacing;
            Button { text: "Commit"; enabled: root.state.confirm_enabled; clicked => { root.perform_import_action(ImportDialogAction.confirm-import, root.state.resolution); } }
            Button { text: "Cancel"; clicked => { root.perform_import_action(ImportDialogAction.cancel-import, 0); } }
        }
    }
}
