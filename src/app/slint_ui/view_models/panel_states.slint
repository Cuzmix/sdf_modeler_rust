import {
    HistoryRowView,
    PropertyBoolFieldView,
    PropertyScalarFieldView,
    ReferenceRowView,
    SceneRowView,
    WorkspaceSummaryRowView,
} from "common_views.slint";

import {
    MenuCommandAction,
    PanelPointerInteractionKind,
    PanelResizeHandle,
    ToolPaletteAction,
} from "ui_actions.slint";

export struct TopBarState {
    viewport_status: string,
    toast_text: string,
    task_status: string,
    gizmo_translate_active: bool,
    gizmo_rotate_active: bool,
    gizmo_scale_active: bool,
    gizmo_local_space: bool,
    camera_is_ortho: bool,
    measurement_mode_active: bool,
    turntable_active: bool,
    file_actions_enabled: bool,
}

export struct ToolPaletteButtonView {
    label: string,
    active: bool,
    action: ToolPaletteAction,
}

export struct ToolPaletteState {
    visible: bool,
    select_tool: ToolPaletteButtonView,
    brush_tools: [ToolPaletteButtonView],
}

export enum MenuKindView {
    none,
    file,
    edit,
    view,
    settings,
    help,
}

export struct MenuStripItemView {
    label: string,
    kind: MenuKindView,
    active: bool,
}

export struct MenuStripState {
    visible: bool,
    items: [MenuStripItemView],
}

export struct MenuDropdownItemView {
    label: string,
    command: MenuCommandAction,
    enabled: bool,
}

export struct MenuDropdownState {
    visible: bool,
    title: string,
    menu: MenuKindView,
    anchor_index: int,
    items: [MenuDropdownItemView],
}

export enum MultiAxisOrientationView {
    world-zero,
    active-object,
}

export enum GroupRotateDirectionView {
    standard,
    inverted,
}

export enum MultiPivotModeView {
    selection-center,
    active-object,
}

export struct SettingsCardState {
    visible: bool,
    multi_axis_orientation: MultiAxisOrientationView,
    group_rotate_direction: GroupRotateDirectionView,
    multi_pivot_mode: MultiPivotModeView,
    auto_save_enabled: bool,
    show_fps_overlay: bool,
    continuous_repaint: bool,
}

export enum PanelKindView {
    tool,
    object-properties,
    render-settings,
    scene,
    history,
    reference-images,
}

export enum ToolPanelModeView {
    select,
    sculpt,
}

export enum PanelOrientationView {
    vertical,
    horizontal,
}

export enum PanelEdgeView {
    left,
    right,
    top,
    bottom,
}

export enum PanelAnchorView {
    left-of-bar,
    right-of-bar,
    above-bar,
    below-bar,
}

export struct PanelLauncherItemView {
    label: string,
    short_label: string,
    icon_key: string,
    active: bool,
    pinned: bool,
    show_drag_indicator: bool,
    kind: PanelKindView,
}

export struct PanelBarViewState {
    visible: bool,
    edge: PanelEdgeView,
    orientation: PanelOrientationView,
    items: [PanelLauncherItemView],
}

export struct PanelFrameView {
    x: float,
    y: float,
    width: float,
    height: float,
}

export struct PanelSheetViewState {
    visible: bool,
    title: string,
    collapsed_title: string,
    collapsed_width: float,
    collapsed_height: float,
    pinned: bool,
    collapsed: bool,
    kind: PanelKindView,
    anchor: PanelAnchorView,
    movable: bool,
    resizable: bool,
    frame: PanelFrameView,
}

export struct PanelFrameworkViewState {
    bar: PanelBarViewState,
    transient_panel: PanelSheetViewState,
    pinned_panels: [PanelSheetViewState],
    panel_interaction_active: bool,
    interaction_panel_kind: PanelKindView,
    active_interaction_kind: PanelPointerInteractionKind,
    active_resize_handle: PanelResizeHandle,
}

export struct OverlayLayoutViewState {
    safe_area_left: float,
