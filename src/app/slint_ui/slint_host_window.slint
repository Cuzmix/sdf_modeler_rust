import {
    HistoryAction,
    ImportDialogAction,
    InspectorEditMode,
    InspectorPanelState,
    MenuCommandAction,
    MenuDropdownState,
    MenuKindView,
    MenuNavigationAction,
    MenuStripState,
    LightEditKind,
    OverlayLayoutViewState,
    MaterialEditKind,
    OperationEditKind,
    PanelFrameworkViewState,
    PanelPointerAction,
    PanelPointerInteractionKind,
    PanelPointerPhase,
    PanelResizeHandle,
    PanelHeaderAction,
    PanelKindView,
    ReferenceImageAction,
    RenderSettingsAction,
    ScenePanelState,
    SceneRowAction,
    SceneTextAction,
    SceneToolbarAction,
    SculptEditKind,
    ToolPaletteAction,
    ToolPaletteState,
    ToolPanelState,
    SettingsCardAction,
    SettingsCardState,
    TopBarAction,
    TopBarState,
    TransformEditKind,
    UtilityPanelState,
    ViewportDoubleClickAction,
    ViewportPathView,
    ViewportPointerAction,
    ViewportScrollAction,
    WorkspaceAction,
    WorkspacePanelState,
} from "view_models.slint";
import { AppTheme } from "theme.slint";
import { MenuDropdown } from "menu_dropdown.slint";
import { MenuStrip } from "menu_strip.slint";
import { PanelBar } from "panel_bar.slint";
import { PanelHost } from "panel_host.slint";
import { SettingsCard } from "settings_card.slint";
import { ToolPalette } from "tool_palette.slint";
import { ViewportPanel } from "viewport_panel.slint";

export component SlintHostWindow inherits Window {
    forward-focus: keyboard_shortcuts_scope;

    in property <string> window_title;
    title: root.window_title;

    in property <image> viewport_image;
    in property <float> viewport_gizmo_viewbox_width;
    in property <float> viewport_gizmo_viewbox_height;
    in property <[ViewportPathView]> viewport_gizmo_paths;
    in property <TopBarState> top_bar_state;
    in property <MenuStripState> menu_strip_state;
    in property <MenuDropdownState> menu_dropdown_state;
    in property <SettingsCardState> settings_card_state;
    in property <ToolPaletteState> tool_palette_state;
    in property <OverlayLayoutViewState> overlay_layout_state;
    in property <PanelFrameworkViewState> panel_framework_state;
    in property <ScenePanelState> scene_panel_state;
    in property <InspectorPanelState> inspector_panel_state;
    in property <ToolPanelState> tool_panel_state;
    in property <UtilityPanelState> utility_panel_state;
    in property <WorkspacePanelState> workspace_panel_state;

    out property <float> viewport_width: viewport_panel.viewport_width;
    out property <float> viewport_height: viewport_panel.viewport_height;
    out property <length> safe_area_left: self.safe-area-insets.left;
    out property <length> safe_area_top: self.safe-area-insets.top;
    out property <length> safe_area_right: self.safe-area-insets.right;
    out property <length> safe_area_bottom: self.safe-area-insets.bottom;
    out property <length> virtual_keyboard_x: self.virtual-keyboard-position.x;
    out property <length> virtual_keyboard_y: self.virtual-keyboard-position.y;
    out property <length> virtual_keyboard_width: self.virtual-keyboard-size.width;
    out property <length> virtual_keyboard_height: self.virtual-keyboard-size.height;
    out property <length> overlay_usable_x: overlay_layout_state.usable_x * 1px;
    out property <length> overlay_usable_y: overlay_layout_state.usable_y * 1px;
    out property <length> overlay_usable_width: overlay_layout_state.usable_width * 1px;
    out property <length> overlay_usable_height: overlay_layout_state.usable_height * 1px;

    callback top_bar_action(action: TopBarAction);
    callback menu_launcher_action(kind: MenuKindView);
    callback menu_command_action(action: MenuCommandAction);
    callback menu_navigation_action(action: MenuNavigationAction);
    callback keyboard_shortcut(text: string, ctrl: bool, shift: bool, alt: bool) -> bool;
    callback settings_card_action(action: SettingsCardAction, value: float);
    callback dismiss_menu_surfaces();
    callback tool_palette_action(action: ToolPaletteAction);
    callback panel_launcher_action(kind: PanelKindView);
    callback panel_header_action(kind: PanelKindView, action: PanelHeaderAction);
    callback panel_pointer_action(kind: PanelKindView, action: PanelPointerAction);
    callback dismiss_transient_panels();
    callback scene_toolbar_action(action: SceneToolbarAction);
    callback scene_row_action(action: SceneRowAction, index: int);
    callback scene_text_action(action: SceneTextAction, text: string);
    callback transform_edit(kind: TransformEditKind, mode: InspectorEditMode, axis: int, value: float);
    callback material_edit(kind: MaterialEditKind, mode: InspectorEditMode, axis: int, value: float);
    callback operation_edit(kind: OperationEditKind, mode: InspectorEditMode, value: float);
    callback sculpt_edit(kind: SculptEditKind, mode: InspectorEditMode, value: float);
    callback light_edit(kind: LightEditKind, mode: InspectorEditMode, axis: int, value: float);
    callback history_action(action: HistoryAction, index: int);
    callback reference_image_action(action: ReferenceImageAction, index: int, value: float);
    callback render_settings_action(action: RenderSettingsAction, value: float);
    callback import_dialog_action(action: ImportDialogAction, value: float);
    callback workspace_action(action: WorkspaceAction);
    callback viewport_pointer_action(action: ViewportPointerAction);
    callback viewport_scroll_action(action: ViewportScrollAction);
    callback viewport_double_click(action: ViewportDoubleClickAction);

    width: 1540px;
    height: 960px;

    Rectangle {
        width: parent.width;
        height: parent.height;
        background: AppTheme.viewport_background;
        clip: true;

        keyboard_shortcuts_scope := FocusScope {
            width: parent.width;
            height: parent.height;
            key-pressed(event) => {
                if root.keyboard_shortcut(
                    event.text,
                    event.modifiers.control,
                    event.modifiers.shift,
                    event.modifiers.alt
                ) {
                    return accept;
                }
                reject
            }
        }

        private property <length> panel_rail_width: 144px;
        private property <length> panel_margin: 20px;
        private property <length> menu_surface_margin: 10px;
        private property <length> menu_item_width: 88px;
        private property <length> menu_surface_gap: 8px;
        private property <length> usable_x: root.overlay_layout_state.usable_width > 0 ? root.overlay_layout_state.usable_x * 1px : 0px;
        private property <length> usable_y: root.overlay_layout_state.usable_height > 0 ? root.overlay_layout_state.usable_y * 1px : 0px;
        private property <length> usable_width: root.overlay_layout_state.usable_width > 0 ? root.overlay_layout_state.usable_width * 1px : parent.width;
        private property <length> usable_height: root.overlay_layout_state.usable_height > 0 ? root.overlay_layout_state.usable_height * 1px : parent.height;
        private property <length> menu_strip_desired_x: self.usable_x + self.panel_margin;
        private property <length> menu_strip_desired_y: self.usable_y + self.panel_margin;
        private property <length> menu_strip_min_x: self.usable_x + self.menu_surface_margin;
        private property <length> menu_strip_max_x: self.usable_x + self.usable_width - menu_strip.width - self.menu_surface_margin;
        private property <length> menu_strip_min_y: self.usable_y + self.menu_surface_margin;
        private property <length> menu_strip_max_y: self.usable_y + self.usable_height - menu_strip.height - self.menu_surface_margin;
        private property <length> menu_strip_x: self.menu_strip_max_x < self.menu_strip_min_x
            ? self.menu_strip_min_x
            : self.menu_strip_desired_x < self.menu_strip_min_x
                ? self.menu_strip_min_x
                : self.menu_strip_desired_x > self.menu_strip_max_x
                    ? self.menu_strip_max_x
                    : self.menu_strip_desired_x;
        private property <length> menu_strip_y: self.menu_strip_max_y < self.menu_strip_min_y
            ? self.menu_strip_min_y
            : self.menu_strip_desired_y < self.menu_strip_min_y
                ? self.menu_strip_min_y
                : self.menu_strip_desired_y > self.menu_strip_max_y
                    ? self.menu_strip_max_y
                    : self.menu_strip_desired_y;
        private property <length> menu_dropdown_desired_x: self.menu_strip_x + root.menu_dropdown_state.anchor_index * self.menu_item_width;
        private property <length> menu_dropdown_below_y: self.menu_strip_y + menu_strip.height + self.menu_surface_gap;
        private property <length> menu_dropdown_above_y: self.menu_strip_y - self.menu_surface_gap - menu_dropdown.height;
        private property <length> menu_dropdown_space_below: self.usable_y + self.usable_height - self.menu_dropdown_below_y;
        private property <length> menu_dropdown_space_above: self.menu_strip_y - self.usable_y - self.menu_surface_gap;
        private property <bool> menu_dropdown_open_above: self.menu_dropdown_space_below < menu_dropdown.height + self.menu_surface_margin
            && self.menu_dropdown_space_above > self.menu_dropdown_space_below;
        private property <length> menu_dropdown_desired_y: self.menu_dropdown_open_above
            ? self.menu_dropdown_above_y
            : self.menu_dropdown_below_y;
        private property <length> menu_dropdown_min_x: self.usable_x + self.menu_surface_margin;
        private property <length> menu_dropdown_max_x: self.usable_x + self.usable_width - menu_dropdown.width - self.menu_surface_margin;
        private property <length> menu_dropdown_min_y: self.usable_y + self.menu_surface_margin;
        private property <length> menu_dropdown_max_y: self.usable_y + self.usable_height - menu_dropdown.height - self.menu_surface_margin;
        private property <length> menu_dropdown_x: self.menu_dropdown_max_x < self.menu_dropdown_min_x
            ? self.menu_dropdown_min_x
            : self.menu_dropdown_desired_x < self.menu_dropdown_min_x
                ? self.menu_dropdown_min_x
                : self.menu_dropdown_desired_x > self.menu_dropdown_max_x
                    ? self.menu_dropdown_max_x
                    : self.menu_dropdown_desired_x;
        private property <length> menu_dropdown_y: self.menu_dropdown_max_y < self.menu_dropdown_min_y
            ? self.menu_dropdown_min_y
            : self.menu_dropdown_desired_y < self.menu_dropdown_min_y
                ? self.menu_dropdown_min_y
                : self.menu_dropdown_desired_y > self.menu_dropdown_max_y
                    ? self.menu_dropdown_max_y
                    : self.menu_dropdown_desired_y;
        private property <length> settings_card_desired_x: self.menu_strip_x + 3 * self.menu_item_width;
        private property <length> settings_card_below_y: self.menu_strip_y + menu_strip.height + self.menu_surface_gap;
        private property <length> settings_card_above_y: self.menu_strip_y - self.menu_surface_gap - settings_card.height;
        private property <length> settings_card_space_below: self.usable_y + self.usable_height - self.settings_card_below_y;
        private property <length> settings_card_space_above: self.menu_strip_y - self.usable_y - self.menu_surface_gap;
        private property <bool> settings_card_open_above: self.settings_card_space_below < settings_card.height + self.menu_surface_margin
            && self.settings_card_space_above > self.settings_card_space_below;
        private property <length> settings_card_desired_y: self.settings_card_open_above
            ? self.settings_card_above_y
            : self.settings_card_below_y;
        private property <length> settings_card_min_x: self.usable_x + self.menu_surface_margin;
        private property <length> settings_card_max_x: self.usable_x + self.usable_width - settings_card.width - self.menu_surface_margin;
        private property <length> settings_card_min_y: self.usable_y + self.menu_surface_margin;
        private property <length> settings_card_max_y: self.usable_y + self.usable_height - settings_card.height - self.menu_surface_margin;
        private property <length> settings_card_x: self.settings_card_max_x < self.settings_card_min_x
            ? self.settings_card_min_x
            : self.settings_card_desired_x < self.settings_card_min_x
                ? self.settings_card_min_x
                : self.settings_card_desired_x > self.settings_card_max_x
                    ? self.settings_card_max_x
                    : self.settings_card_desired_x;
        private property <length> settings_card_y: self.settings_card_max_y < self.settings_card_min_y
            ? self.settings_card_min_y
            : self.settings_card_desired_y < self.settings_card_min_y
                ? self.settings_card_min_y
                : self.settings_card_desired_y > self.settings_card_max_y
                    ? self.settings_card_max_y
                    : self.settings_card_desired_y;
        private property <MouseCursor> active_panel_cursor: root.panel_framework_state.active_interaction_kind == PanelPointerInteractionKind.move
            ? grabbing
            : root.panel_framework_state.active_resize_handle == PanelResizeHandle.top
                || root.panel_framework_state.active_resize_handle == PanelResizeHandle.bottom
                ? ns-resize
                : root.panel_framework_state.active_resize_handle == PanelResizeHandle.left
                    || root.panel_framework_state.active_resize_handle == PanelResizeHandle.right
                    ? ew-resize
                    : root.panel_framework_state.active_resize_handle == PanelResizeHandle.top-left
                        || root.panel_framework_state.active_resize_handle == PanelResizeHandle.bottom-right
                        ? nwse-resize
                        : root.panel_framework_state.active_resize_handle == PanelResizeHandle.top-right
                            || root.panel_framework_state.active_resize_handle == PanelResizeHandle.bottom-left
                            ? nesw-resize
                            : default;

        viewport_panel := ViewportPanel {
            width: parent.width;
            height: parent.height;
            viewport_image: root.viewport_image;
            viewport_gizmo_viewbox_width: root.viewport_gizmo_viewbox_width;
            viewport_gizmo_viewbox_height: root.viewport_gizmo_viewbox_height;
            viewport_gizmo_paths: root.viewport_gizmo_paths;
            viewport_pointer_action(action) => {
                root.viewport_pointer_action(action);
            }
            viewport_scroll_action(action) => {
                root.viewport_scroll_action(action);
            }
            viewport_double_click(action) => {
                root.viewport_double_click(action);
            }
        }

        if root.panel_framework_state.transient_panel.visible && !root.panel_framework_state.panel_interaction_active : Rectangle {
            width: parent.width;
            height: parent.height;
            background: AppTheme.overlay_panel_backdrop;
            opacity: 0.12;

            TouchArea {
                width: parent.width;
                height: parent.height;
                clicked => {
                    root.dismiss_transient_panels();
                }
            }
        }

        for panel in root.panel_framework_state.pinned_panels : PanelHost {
            x: panel.frame.x * 1px;
            y: panel.frame.y * 1px;
            panel: panel;
            scene_state: root.scene_panel_state;
            inspector_state: root.inspector_panel_state;
            tool_state: root.tool_panel_state;
            utility_state: root.utility_panel_state;
            interaction_active: root.panel_framework_state.panel_interaction_active
                && root.panel_framework_state.interaction_panel_kind == self.panel.kind;
            active_interaction_kind: root.panel_framework_state.active_interaction_kind;
            active_resize_handle: root.panel_framework_state.active_resize_handle;
            panel_header_action(kind, action) => {
                root.panel_header_action(kind, action);
            }
            panel_pointer_action(kind, action) => {
                root.panel_pointer_action(kind, action);
            }
            scene_toolbar_action(action) => {
                root.scene_toolbar_action(action);
            }
            scene_row_action(action, index) => {
                root.scene_row_action(action, index);
            }
            scene_text_action(action, text) => {
                root.scene_text_action(action, text);
            }
            transform_edit(kind, mode, axis, value) => { root.transform_edit(kind, mode, axis, value); }
            material_edit(kind, mode, axis, value) => { root.material_edit(kind, mode, axis, value); }
            operation_edit(kind, mode, value) => { root.operation_edit(kind, mode, value); }
            sculpt_edit(kind, mode, value) => { root.sculpt_edit(kind, mode, value); }
            light_edit(kind, mode, axis, value) => { root.light_edit(kind, mode, axis, value); }
            history_action(action, index) => { root.history_action(action, index); }
            reference_image_action(action, index, value) => { root.reference_image_action(action, index, value); }
            render_settings_action(action, value) => { root.render_settings_action(action, value); }
        }

        transient_panel_host := PanelHost {
            x: root.panel_framework_state.transient_panel.frame.x * 1px;
            y: root.panel_framework_state.transient_panel.frame.y * 1px;
            panel: root.panel_framework_state.transient_panel;
            scene_state: root.scene_panel_state;
            inspector_state: root.inspector_panel_state;
            tool_state: root.tool_panel_state;
            utility_state: root.utility_panel_state;
            interaction_active: root.panel_framework_state.panel_interaction_active
                && root.panel_framework_state.interaction_panel_kind == self.panel.kind;
            active_interaction_kind: root.panel_framework_state.active_interaction_kind;
            active_resize_handle: root.panel_framework_state.active_resize_handle;
            panel_header_action(kind, action) => {
                root.panel_header_action(kind, action);
            }
            panel_pointer_action(kind, action) => {
                root.panel_pointer_action(kind, action);
            }
            scene_toolbar_action(action) => {
                root.scene_toolbar_action(action);
            }
            scene_row_action(action, index) => {
                root.scene_row_action(action, index);
            }
            scene_text_action(action, text) => {
                root.scene_text_action(action, text);
            }
            transform_edit(kind, mode, axis, value) => { root.transform_edit(kind, mode, axis, value); }
            material_edit(kind, mode, axis, value) => { root.material_edit(kind, mode, axis, value); }
            operation_edit(kind, mode, value) => { root.operation_edit(kind, mode, value); }
            sculpt_edit(kind, mode, value) => { root.sculpt_edit(kind, mode, value); }
            light_edit(kind, mode, axis, value) => { root.light_edit(kind, mode, axis, value); }
            history_action(action, index) => { root.history_action(action, index); }
            reference_image_action(action, index, value) => { root.reference_image_action(action, index, value); }
            render_settings_action(action, value) => { root.render_settings_action(action, value); }
        }

        panel_bar := PanelBar {
            state: root.panel_framework_state.bar;
            width: parent.panel_rail_width;
            x: parent.usable_x + parent.usable_width - self.width - parent.panel_margin;
            y: parent.usable_y + parent.panel_margin;
            toggle_panel(kind) => {
                root.panel_launcher_action(kind);
            }
        }

        tool_palette := ToolPalette {
            state: root.tool_palette_state;
            width: parent.usable_width - 48px > 620px ? 620px : parent.usable_width - 48px > 260px ? parent.usable_width - 48px : 260px;
            x: parent.usable_x + (parent.usable_width - self.width) / 2;
            y: parent.usable_y + parent.usable_height - self.height - 28px;
            perform_action(action) => {
                root.tool_palette_action(action);
            }
        }

        if (root.menu_dropdown_state.visible || root.settings_card_state.visible)
            && !root.panel_framework_state.panel_interaction_active : TouchArea {
            width: parent.width;
            height: parent.height;
            pointer-event(event) => {
            }
            scroll-event(event) => {
                accept
            }
            clicked => {
                root.dismiss_menu_surfaces();
            }
        }

        menu_strip := MenuStrip {
            state: root.menu_strip_state;
            item_width: parent.menu_item_width;
            x: parent.menu_strip_x;
            y: parent.menu_strip_y;
            toggle_menu(kind) => {
                root.menu_launcher_action(kind);
            }
        }

        menu_dropdown := MenuDropdown {
            state: root.menu_dropdown_state;
            x: parent.menu_dropdown_x;
            y: parent.menu_dropdown_y;
            execute_command(action) => {
                root.menu_command_action(action);
            }
            navigate(action) => {
                root.menu_navigation_action(action);
            }
        }

        settings_card := SettingsCard {
            state: root.settings_card_state;
            x: parent.settings_card_x;
            y: parent.settings_card_y;
            perform_action(action, value) => {
                root.settings_card_action(action, value);
            }
            dismiss_requested() => {
                root.dismiss_menu_surfaces();
            }
        }

        private property <bool> menu_surfaces_open: root.menu_dropdown_state.visible || root.settings_card_state.visible;
        changed menu_surfaces_open => {
            if !self.menu_surfaces_open {
                menu_strip.focus_strip();
            }
        }

        if root.panel_framework_state.panel_interaction_active : TouchArea {
            width: parent.width;
            height: parent.height;
            mouse-cursor: parent.active_panel_cursor;

            pointer-event(event) => {
                root.panel_pointer_action(root.panel_framework_state.interaction_panel_kind, {
                    phase: event.kind == PointerEventKind.down ? PanelPointerPhase.down : event.kind == PointerEventKind.up ? PanelPointerPhase.up : event.kind == PointerEventKind.cancel ? PanelPointerPhase.cancel : PanelPointerPhase.move,
                    interaction: PanelPointerInteractionKind.move,
                    handle: PanelResizeHandle.none,
                    x: self.mouse_x / 1px,
                    y: self.mouse_y / 1px,
                });
            }
        }
    }
}
