import { HorizontalBox, VerticalBox } from "std-widgets.slint";
import { ImportDialogAction, InspectorEditKind, InspectorEditMode, InspectorPanelState, ReferenceImageAction, RenderSettingsAction, SceneAction, ScenePanelState, TopBarAction, TopBarState, UtilityPanelState, ViewportPathView } from "view_models.slint";
import { AppTheme } from "theme.slint";
import { RightSidebar } from "right_sidebar.slint";
import { ScenePanel } from "scene_panel.slint";
import { TopBar } from "top_bar.slint";
import { ViewportPanel } from "viewport_panel.slint";

export component SlintHostWindow inherits Window {
    in property <string> window_title;
    title: root.window_title;

    in property <image> viewport_image;
    in property <float> viewport_gizmo_viewbox_width;
    in property <float> viewport_gizmo_viewbox_height;
    in property <[ViewportPathView]> viewport_gizmo_paths;
    in property <TopBarState> top_bar_state;
    in property <ScenePanelState> scene_panel_state;
    in property <InspectorPanelState> inspector_panel_state;
    in property <UtilityPanelState> utility_panel_state;

    out property <float> viewport_width: viewport_panel.viewport_width;
    out property <float> viewport_height: viewport_panel.viewport_height;

    callback top_bar_action(action: TopBarAction);
    callback scene_action(action: SceneAction, index: int, text: string);
    callback inspector_edit(kind: InspectorEditKind, mode: InspectorEditMode, axis: int, value: float);
    callback reference_image_action(action: ReferenceImageAction, index: int, value: float);
    callback render_settings_action(action: RenderSettingsAction, value: float);
    callback import_dialog_action(action: ImportDialogAction, value: float);
    callback viewport_pointer_event(event: PointerEvent, x: float, y: float);
    callback viewport_scroll_event(event: PointerScrollEvent);
    callback viewport_double_clicked(x: float, y: float);

    width: 1480px;
    height: 920px;

    VerticalBox {
        spacing: AppTheme.frame_spacing;

        TopBar {
            state: root.top_bar_state;
            perform_action(action) => { root.top_bar_action(action); }
        }

        HorizontalBox {
            spacing: AppTheme.frame_spacing;
            vertical-stretch: 1;

            ScenePanel {
                state: root.scene_panel_state;
                perform_action(action, index, text) => { root.scene_action(action, index, text); }
            }

            viewport_panel := ViewportPanel {
                viewport_image: root.viewport_image;
                viewport_gizmo_viewbox_width: root.viewport_gizmo_viewbox_width;
                viewport_gizmo_viewbox_height: root.viewport_gizmo_viewbox_height;
                viewport_gizmo_paths: root.viewport_gizmo_paths;
                viewport_pointer_event(event, x, y) => { root.viewport_pointer_event(event, x, y); }
                viewport_scroll_event(event) => { root.viewport_scroll_event(event); }
                viewport_double_clicked(x, y) => { root.viewport_double_clicked(x, y); }
            }

            RightSidebar {
                inspector_state: root.inspector_panel_state;
                utility_state: root.utility_panel_state;
                edit_inspector(kind, mode, axis, value) => { root.inspector_edit(kind, mode, axis, value); }
                reference_image_action(action, index, value) => { root.reference_image_action(action, index, value); }
                render_settings_action(action, value) => { root.render_settings_action(action, value); }
                import_dialog_action(action, value) => { root.import_dialog_action(action, value); }
            }
        }
    }
}
