import { Button, HorizontalBox, ScrollView, VerticalBox } from "std-widgets.slint";
import { PanelResizeHandles } from "panel_resize_handles.slint";
import { AppTheme } from "theme.slint";
import {
    PanelHeaderAction,
    PanelPointerAction,
    PanelPointerInteractionKind,
    PanelPointerPhase,
    PanelResizeHandle,
} from "view_models.slint";

export component PanelSheet inherits Rectangle {
    in property <string> title;
    in property <string> collapsed_title;
    in property <bool> pinned;
    in property <bool> collapsed;
    in property <length> expanded_width: 390px;
    in property <length> expanded_height: 420px;
    in property <length> collapsed_width: 320px;
    in property <length> collapsed_height: 76px;
    in property <bool> movable;
    in property <bool> resizable;
    in property <bool> interaction_active;
    in property <PanelPointerInteractionKind> active_interaction_kind: PanelPointerInteractionKind.move;
    in property <PanelResizeHandle> active_resize_handle: PanelResizeHandle.none;

    callback header_action(action: PanelHeaderAction);
    callback pointer_action(action: PanelPointerAction);

    private property <length> header_height: 52px;
    private property <length> divider_y: AppTheme.overlay_panel_padding + header_height + AppTheme.section_spacing;
    private property <length> body_y: divider_y + 1px + AppTheme.section_spacing;
    private property <string> display_title: root.collapsed ? root.collapsed_title : root.title;

    clip: true;
    border-radius: AppTheme.overlay_panel_radius;
    border-width: 1px;
    border-color: AppTheme.overlay_panel_border;
    background: AppTheme.overlay_panel_background;
    width: collapsed ? collapsed_width : expanded_width;
    height: collapsed ? collapsed_height : expanded_height;

    TouchArea {
        width: parent.width;
        height: parent.height;
    }

    if root.movable : grip_host := Rectangle {
        x: (parent.width - self.width) / 2;
        y: 12px;
        width: 88px;
        height: 30px;
        private property <bool> active_drag: root.interaction_active
            && root.active_interaction_kind == PanelPointerInteractionKind.move;
        private property <bool> grip_highlighted: grip_touch.has-hover || grip_touch.pressed || self.active_drag;
        background: #00000000;

        Rectangle {
            width: parent.width;
            height: 18px;
            y: 0px;
            border-radius: 9px;
            border-width: grip_host.grip_highlighted ? 1px : 0px;
            border-color: AppTheme.overlay_button_active_border;
            background: AppTheme.overlay_button_active_background;
            opacity: grip_host.active_drag ? 0.38 : grip_host.grip_highlighted ? 0.2 : 0.0;
        }

        for dot in [0, 1, 2, 3, 4, 5] : Rectangle {
            width: 4px;
            height: 4px;
            x: dot * 12px + 12px;
            y: 7px;
            border-radius: 2px;
            background: AppTheme.overlay_button_text;
            opacity: grip_host.active_drag ? 1.0 : grip_host.grip_highlighted ? 0.92 : 0.75;
        }

        grip_touch := TouchArea {
            x: 0px;
            y: 8px;
            width: parent.width;
            height: 22px;
            mouse-cursor: grip_host.active_drag ? grabbing : grab;

            pointer-event(event) => {
                root.pointer_action({
                    phase: event.kind == PointerEventKind.down ? PanelPointerPhase.down : event.kind == PointerEventKind.up ? PanelPointerPhase.up : event.kind == PointerEventKind.cancel ? PanelPointerPhase.cancel : PanelPointerPhase.move,
                    interaction: PanelPointerInteractionKind.move,
                    handle: PanelResizeHandle.none,
                    x: parent.x / 1px + self.mouse_x / 1px,
                    y: parent.y / 1px + self.mouse_y / 1px,
                });
            }
        }
    }

    header := HorizontalBox {
        x: AppTheme.overlay_panel_padding;
        y: AppTheme.overlay_panel_padding + (root.movable ? 14px : 0px);
        width: parent.width - AppTheme.overlay_panel_padding * 2;
        height: root.header_height - (root.movable ? 14px : 0px);
        spacing: AppTheme.section_spacing;

        Text {
            vertical-alignment: center;
            text: root.display_title;
            color: AppTheme.overlay_button_text;
            font-size: 16px;
        }

        if !root.collapsed : Rectangle { horizontal-stretch: 1; }

        Button {
            text: root.collapsed ? "Expand" : "Collapse";
            clicked => { root.header_action(PanelHeaderAction.toggle-collapsed); }
        }
        Button {
            text: root.pinned ? "Unpin" : "Pin";
            clicked => {
                root.header_action(root.pinned ? PanelHeaderAction.unpin : PanelHeaderAction.pin);
            }
        }
        Button {
            text: "Close";
            clicked => { root.header_action(PanelHeaderAction.close); }
        }

        if root.collapsed : Rectangle { horizontal-stretch: 1; }
    }

    Rectangle {
        x: AppTheme.overlay_panel_padding;
        y: root.divider_y;
        width: parent.width - AppTheme.overlay_panel_padding * 2;
        height: 1px;
        background: AppTheme.overlay_divider;
    }

    ScrollView {
        visible: !root.collapsed;
        x: AppTheme.overlay_panel_padding;
        y: root.body_y;
        width: parent.width - AppTheme.overlay_panel_padding * 2;
        height: root.collapsed ? 0px : parent.height - root.body_y - AppTheme.overlay_panel_padding;

        VerticalBox {
            spacing: AppTheme.section_spacing;
            @children
        }
    }

    if root.resizable : PanelResizeHandles {
        width: parent.width;
        height: parent.height;
        interaction_active: root.interaction_active
            && root.active_interaction_kind == PanelPointerInteractionKind.resize;
        active_resize_handle: root.active_resize_handle;
        pointer_action(action) => {
            root.pointer_action(action);
        }
    }
}
