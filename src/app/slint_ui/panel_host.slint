import { HistoryPanel } from "history_panel.slint";
import { InspectorPanel } from "inspector_panel.slint";
import { PanelSheet } from "panel_sheet.slint";
import { ReferenceImagesPanel } from "reference_images_panel.slint";
import { RenderSettingsPanel } from "render_settings_panel.slint";
import { ScenePanel } from "scene_panel.slint";
import { ToolPanel } from "tool_panel.slint";
import {
    HistoryAction,
    InspectorEditMode,
    InspectorPanelState,
    LightEditKind,
    MaterialEditKind,
    PanelPointerAction,
    PanelPointerInteractionKind,
    ReferenceImageAction,
    OperationEditKind,
    PanelHeaderAction,
    PanelKindView,
    PanelResizeHandle,
    PanelSheetViewState,
    RenderSettingsAction,
    ScenePanelState,
    SceneRowAction,
    SceneTextAction,
    SceneToolbarAction,
    SculptEditKind,
    ToolPanelState,
    TransformEditKind,
    UtilityPanelState,
} from "view_models.slint";

export component PanelHost inherits Rectangle {
    in property <PanelSheetViewState> panel;
    in property <ScenePanelState> scene_state;
    in property <InspectorPanelState> inspector_state;
    in property <ToolPanelState> tool_state;
    in property <UtilityPanelState> utility_state;
    in property <bool> interaction_active;
    in property <PanelPointerInteractionKind> active_interaction_kind;
    in property <PanelResizeHandle> active_resize_handle;

    callback panel_header_action(kind: PanelKindView, action: PanelHeaderAction);
    callback panel_pointer_action(kind: PanelKindView, action: PanelPointerAction);
    callback scene_toolbar_action(action: SceneToolbarAction);
    callback scene_row_action(action: SceneRowAction, index: int);
    callback scene_text_action(action: SceneTextAction, text: string);
    callback transform_edit(kind: TransformEditKind, mode: InspectorEditMode, axis: int, value: float);
    callback material_edit(kind: MaterialEditKind, mode: InspectorEditMode, axis: int, value: float);
    callback operation_edit(kind: OperationEditKind, mode: InspectorEditMode, value: float);
    callback sculpt_edit(kind: SculptEditKind, mode: InspectorEditMode, value: float);
    callback light_edit(kind: LightEditKind, mode: InspectorEditMode, axis: int, value: float);
    callback history_action(action: HistoryAction, index: int);
    callback reference_image_action(action: ReferenceImageAction, index: int, value: float);
    callback render_settings_action(action: RenderSettingsAction, value: float);

    visible: panel.visible;

    sheet := PanelSheet {
        expanded_width: root.panel.frame.width * 1px;
        expanded_height: root.panel.frame.height * 1px;
        collapsed_width: root.panel.collapsed_width * 1px;
        collapsed_height: root.panel.collapsed_height * 1px;
        title: root.panel.title;
        collapsed_title: root.panel.collapsed_title;
        pinned: root.panel.pinned;
        collapsed: root.panel.collapsed;
        movable: root.panel.movable;
        resizable: root.panel.resizable;
        interaction_active: root.interaction_active;
        active_interaction_kind: root.active_interaction_kind;
        active_resize_handle: root.active_resize_handle;
        header_action(action) => {
            root.panel_header_action(root.panel.kind, action);
        }
        pointer_action(action) => {
            root.panel_pointer_action(root.panel.kind, {
                phase: action.phase,
                interaction: action.interaction,
                handle: action.handle,
                x: root.panel.frame.x + action.x,
                y: root.panel.frame.y + action.y,
            });
        }

        if root.panel.kind == PanelKindView.tool : ToolPanel {
            state: root.tool_state;
            transform_edit(kind, mode, axis, value) => { root.transform_edit(kind, mode, axis, value); }
            material_edit(kind, mode, axis, value) => { root.material_edit(kind, mode, axis, value); }
            operation_edit(kind, mode, value) => { root.operation_edit(kind, mode, value); }
            sculpt_edit(kind, mode, value) => { root.sculpt_edit(kind, mode, value); }
            light_edit(kind, mode, axis, value) => { root.light_edit(kind, mode, axis, value); }
        }

        if root.panel.kind == PanelKindView.object-properties : InspectorPanel {
            state: root.inspector_state;
            transform_edit(kind, mode, axis, value) => { root.transform_edit(kind, mode, axis, value); }
            material_edit(kind, mode, axis, value) => { root.material_edit(kind, mode, axis, value); }
            operation_edit(kind, mode, value) => { root.operation_edit(kind, mode, value); }
            sculpt_edit(kind, mode, value) => { root.sculpt_edit(kind, mode, value); }
            light_edit(kind, mode, axis, value) => { root.light_edit(kind, mode, axis, value); }
        }

        if root.panel.kind == PanelKindView.scene : ScenePanel {
            state: root.scene_state;
            toolbar_action(action) => { root.scene_toolbar_action(action); }
            row_action(action, index) => { root.scene_row_action(action, index); }
            text_action(action, text) => { root.scene_text_action(action, text); }
        }

        if root.panel.kind == PanelKindView.history : HistoryPanel {
            history_summary: root.utility_state.history_summary;
            history_rows: root.utility_state.history_rows;
            perform_history_action(action, index) => { root.history_action(action, index); }
        }

        if root.panel.kind == PanelKindView.reference-images : ReferenceImagesPanel {
            summary: root.utility_state.reference_summary;
            reference_rows: root.utility_state.reference_rows;
            perform_reference_action(action, index, value) => {
                root.reference_image_action(action, index, value);
            }
        }

        if root.panel.kind == PanelKindView.render-settings : RenderSettingsPanel {
            state: root.utility_state.render_settings;
            perform_render_action(action, value) => { root.render_settings_action(action, value); }
        }
    }

    width: sheet.width;
    height: sheet.height;
}
