import { CheckBox, SpinBox, VerticalBox } from "std-widgets.slint";
import { NudgeRow } from "nudge_row.slint";
import { AppTheme } from "theme.slint";
import { UtilityAction } from "view_models.slint";

export component RenderSettingsPanel inherits VerticalBox {
    in property <bool> render_show_grid;
    in property <bool> render_show_node_labels;
    in property <bool> render_show_bounding_box;
    in property <bool> render_show_light_gizmos;
    in property <bool> render_shadows_enabled;
    in property <bool> render_ao_enabled;
    in property <int> export_resolution;
    in property <bool> adaptive_export;

    callback perform_action(action: UtilityAction, index: int, value: float);

    spacing: AppTheme.section_spacing;

    Text { text: "Render"; }
    CheckBox { text: "Show grid"; checked: root.render_show_grid; toggled => { root.perform_action(UtilityAction.set-render-show-grid, -1, self.checked ? 1.0 : 0.0); } }
    CheckBox { text: "Node labels"; checked: root.render_show_node_labels; toggled => { root.perform_action(UtilityAction.set-render-show-node-labels, -1, self.checked ? 1.0 : 0.0); } }
    CheckBox { text: "Bounding box"; checked: root.render_show_bounding_box; toggled => { root.perform_action(UtilityAction.set-render-show-bounding-box, -1, self.checked ? 1.0 : 0.0); } }
    CheckBox { text: "Light gizmos"; checked: root.render_show_light_gizmos; toggled => { root.perform_action(UtilityAction.set-render-show-light-gizmos, -1, self.checked ? 1.0 : 0.0); } }
    CheckBox { text: "Shadows"; checked: root.render_shadows_enabled; toggled => { root.perform_action(UtilityAction.set-render-shadows-enabled, -1, self.checked ? 1.0 : 0.0); } }
    CheckBox { text: "Ambient occlusion"; checked: root.render_ao_enabled; toggled => { root.perform_action(UtilityAction.set-render-ao-enabled, -1, self.checked ? 1.0 : 0.0); } }
    NudgeRow { minus_label: "Exp-"; value_label: "Export Res " + root.export_resolution; plus_label: "Exp+"; step_down => { root.perform_action(UtilityAction.nudge-export-resolution, -1, -16); } step_up => { root.perform_action(UtilityAction.nudge-export-resolution, -1, 16); } }
    SpinBox { minimum: 16; maximum: 2048; step-size: 16; value: root.export_resolution; edited => { root.perform_action(UtilityAction.set-export-resolution, -1, self.value); } }
    CheckBox { text: "Adaptive export"; checked: root.adaptive_export; toggled => { root.perform_action(UtilityAction.set-adaptive-export, -1, self.checked ? 1.0 : 0.0); } }
}
