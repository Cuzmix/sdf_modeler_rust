import { CheckBox, Slider, SpinBox, VerticalBox } from "std-widgets.slint";
import { NudgeRow } from "nudge_row.slint";
import { AppTheme } from "theme.slint";
import { InspectorEditMode, InspectorPanelState, LightEditKind, MaterialEditKind, OperationEditKind, SculptEditKind, TransformEditKind } from "view_models.slint";

export component InspectorPanel inherits VerticalBox {
    in property <InspectorPanelState> state;

    callback transform_edit(kind: TransformEditKind, mode: InspectorEditMode, axis: int, value: float);
    callback material_edit(kind: MaterialEditKind, mode: InspectorEditMode, axis: int, value: float);
    callback operation_edit(kind: OperationEditKind, mode: InspectorEditMode, value: float);
    callback sculpt_edit(kind: SculptEditKind, mode: InspectorEditMode, value: float);
    callback light_edit(kind: LightEditKind, mode: InspectorEditMode, axis: int, value: float);

    spacing: AppTheme.section_spacing;

    Text { text: root.state.title; }
    Text { text: root.state.chips; wrap: word-wrap; }
    Text { text: root.state.property_summary; wrap: word-wrap; }
    Text { text: root.state.display; wrap: word-wrap; }

    if root.state.has_transform : VerticalBox {
        spacing: AppTheme.section_spacing;
        Text { text: "Transform"; }
        NudgeRow { minus_label: "PX-"; value_label: "X " + root.state.transform_pos_x; plus_label: "PX+"; step_down => { root.transform_edit(TransformEditKind.position, InspectorEditMode.nudge, 0, -0.1); } step_up => { root.transform_edit(TransformEditKind.position, InspectorEditMode.nudge, 0, 0.1); } }
        NudgeRow { minus_label: "PY-"; value_label: "Y " + root.state.transform_pos_y; plus_label: "PY+"; step_down => { root.transform_edit(TransformEditKind.position, InspectorEditMode.nudge, 1, -0.1); } step_up => { root.transform_edit(TransformEditKind.position, InspectorEditMode.nudge, 1, 0.1); } }
        NudgeRow { minus_label: "PZ-"; value_label: "Z " + root.state.transform_pos_z; plus_label: "PZ+"; step_down => { root.transform_edit(TransformEditKind.position, InspectorEditMode.nudge, 2, -0.1); } step_up => { root.transform_edit(TransformEditKind.position, InspectorEditMode.nudge, 2, 0.1); } }
        NudgeRow { minus_label: "RX-"; value_label: "RX " + root.state.transform_rot_x; plus_label: "RX+"; step_down => { root.transform_edit(TransformEditKind.rotation, InspectorEditMode.nudge, 0, -5); } step_up => { root.transform_edit(TransformEditKind.rotation, InspectorEditMode.nudge, 0, 5); } }
        NudgeRow { minus_label: "RY-"; value_label: "RY " + root.state.transform_rot_y; plus_label: "RY+"; step_down => { root.transform_edit(TransformEditKind.rotation, InspectorEditMode.nudge, 1, -5); } step_up => { root.transform_edit(TransformEditKind.rotation, InspectorEditMode.nudge, 1, 5); } }
        NudgeRow { minus_label: "RZ-"; value_label: "RZ " + root.state.transform_rot_z; plus_label: "RZ+"; step_down => { root.transform_edit(TransformEditKind.rotation, InspectorEditMode.nudge, 2, -5); } step_up => { root.transform_edit(TransformEditKind.rotation, InspectorEditMode.nudge, 2, 5); } }

        if root.state.can_scale : VerticalBox {
            spacing: AppTheme.section_spacing;
            NudgeRow { minus_label: "SX-"; value_label: "SX " + root.state.selected_scale_x; plus_label: "SX+"; step_down => { root.transform_edit(TransformEditKind.scale, InspectorEditMode.nudge, 0, -0.1); } step_up => { root.transform_edit(TransformEditKind.scale, InspectorEditMode.nudge, 0, 0.1); } }
            NudgeRow { minus_label: "SY-"; value_label: "SY " + root.state.selected_scale_y; plus_label: "SY+"; step_down => { root.transform_edit(TransformEditKind.scale, InspectorEditMode.nudge, 1, -0.1); } step_up => { root.transform_edit(TransformEditKind.scale, InspectorEditMode.nudge, 1, 0.1); } }
            NudgeRow { minus_label: "SZ-"; value_label: "SZ " + root.state.selected_scale_z; plus_label: "SZ+"; step_down => { root.transform_edit(TransformEditKind.scale, InspectorEditMode.nudge, 2, -0.1); } step_up => { root.transform_edit(TransformEditKind.scale, InspectorEditMode.nudge, 2, 0.1); } }
        }
    }

    if root.state.has_material : VerticalBox {
        spacing: AppTheme.section_spacing;
        Text { text: "Material"; }
        NudgeRow { minus_label: "R-"; value_label: "R " + root.state.material_color_r; plus_label: "R+"; step_down => { root.material_edit(MaterialEditKind.color, InspectorEditMode.nudge, 0, -0.05); } step_up => { root.material_edit(MaterialEditKind.color, InspectorEditMode.nudge, 0, 0.05); } }
        NudgeRow { minus_label: "G-"; value_label: "G " + root.state.material_color_g; plus_label: "G+"; step_down => { root.material_edit(MaterialEditKind.color, InspectorEditMode.nudge, 1, -0.05); } step_up => { root.material_edit(MaterialEditKind.color, InspectorEditMode.nudge, 1, 0.05); } }
        NudgeRow { minus_label: "B-"; value_label: "B " + root.state.material_color_b; plus_label: "B+"; step_down => { root.material_edit(MaterialEditKind.color, InspectorEditMode.nudge, 2, -0.05); } step_up => { root.material_edit(MaterialEditKind.color, InspectorEditMode.nudge, 2, 0.05); } }
        NudgeRow { minus_label: "Rgh-"; value_label: "Roughness " + root.state.material_roughness; plus_label: "Rgh+"; step_down => { root.material_edit(MaterialEditKind.roughness, InspectorEditMode.nudge, -1, -0.05); } step_up => { root.material_edit(MaterialEditKind.roughness, InspectorEditMode.nudge, -1, 0.05); } }
        Slider { minimum: 0; maximum: 1; step: 0.01; value: root.state.material_roughness; changed(value) => { root.material_edit(MaterialEditKind.roughness, InspectorEditMode.set, -1, value); } }
        NudgeRow { minus_label: "Met-"; value_label: "Metallic " + root.state.material_metallic; plus_label: "Met+"; step_down => { root.material_edit(MaterialEditKind.metallic, InspectorEditMode.nudge, -1, -0.05); } step_up => { root.material_edit(MaterialEditKind.metallic, InspectorEditMode.nudge, -1, 0.05); } }
        Slider { minimum: 0; maximum: 1; step: 0.01; value: root.state.material_metallic; changed(value) => { root.material_edit(MaterialEditKind.metallic, InspectorEditMode.set, -1, value); } }
    }

    if root.state.has_operation : VerticalBox {
        spacing: AppTheme.section_spacing;
        Text { text: root.state.operation_label; }
        NudgeRow { minus_label: "K-"; value_label: "Smooth " + root.state.operation_smooth_k; plus_label: "K+"; step_down => { root.operation_edit(OperationEditKind.smooth-k, InspectorEditMode.nudge, -0.05); } step_up => { root.operation_edit(OperationEditKind.smooth-k, InspectorEditMode.nudge, 0.05); } }
        NudgeRow { minus_label: "Steps-"; value_label: "Steps " + root.state.operation_steps; plus_label: "Steps+"; step_down => { root.operation_edit(OperationEditKind.steps, InspectorEditMode.nudge, -1); } step_up => { root.operation_edit(OperationEditKind.steps, InspectorEditMode.nudge, 1); } }
        Slider { minimum: 0; maximum: 32; step: 1; value: root.state.operation_steps; changed(value) => { root.operation_edit(OperationEditKind.steps, InspectorEditMode.set, value); } }
        NudgeRow { minus_label: "Blend-"; value_label: "Blend " + root.state.operation_color_blend; plus_label: "Blend+"; step_down => { root.operation_edit(OperationEditKind.color-blend, InspectorEditMode.nudge, -0.05); } step_up => { root.operation_edit(OperationEditKind.color-blend, InspectorEditMode.nudge, 0.05); } }
        Slider { minimum: -1; maximum: 1; step: 0.01; value: root.state.operation_color_blend; changed(value) => { root.operation_edit(OperationEditKind.color-blend, InspectorEditMode.set, value); } }
    }

    if root.state.has_sculpt : VerticalBox {
        spacing: AppTheme.section_spacing;
        Text { text: "Sculpt"; }
        NudgeRow { minus_label: "Res-"; value_label: "Resolution " + root.state.sculpt_resolution; plus_label: "Res+"; step_down => { root.sculpt_edit(SculptEditKind.resolution, InspectorEditMode.nudge, -8); } step_up => { root.sculpt_edit(SculptEditKind.resolution, InspectorEditMode.nudge, 8); } }
        SpinBox { minimum: 8; maximum: 512; step-size: 8; value: root.state.sculpt_resolution; edited => { root.sculpt_edit(SculptEditKind.resolution, InspectorEditMode.set, self.value); } }
        NudgeRow { minus_label: "Layer-"; value_label: "Layer " + root.state.sculpt_layer_intensity; plus_label: "Layer+"; step_down => { root.sculpt_edit(SculptEditKind.layer-intensity, InspectorEditMode.nudge, -0.1); } step_up => { root.sculpt_edit(SculptEditKind.layer-intensity, InspectorEditMode.nudge, 0.1); } }
        Slider { minimum: 0; maximum: 4; step: 0.01; value: root.state.sculpt_layer_intensity; changed(value) => { root.sculpt_edit(SculptEditKind.layer-intensity, InspectorEditMode.set, value); } }
        NudgeRow { minus_label: "Brush-"; value_label: "Radius " + root.state.sculpt_brush_radius; plus_label: "Brush+"; step_down => { root.sculpt_edit(SculptEditKind.brush-radius, InspectorEditMode.nudge, -0.05); } step_up => { root.sculpt_edit(SculptEditKind.brush-radius, InspectorEditMode.nudge, 0.05); } }
        Slider { minimum: 0.05; maximum: 2.0; step: 0.01; value: root.state.sculpt_brush_radius; changed(value) => { root.sculpt_edit(SculptEditKind.brush-radius, InspectorEditMode.set, value); } }
        NudgeRow { minus_label: "Strength-"; value_label: "Strength " + root.state.sculpt_brush_strength; plus_label: "Strength+"; step_down => { root.sculpt_edit(SculptEditKind.brush-strength, InspectorEditMode.nudge, -0.05); } step_up => { root.sculpt_edit(SculptEditKind.brush-strength, InspectorEditMode.nudge, 0.05); } }
        Slider { minimum: -2; maximum: 2; step: 0.01; value: root.state.sculpt_brush_strength; changed(value) => { root.sculpt_edit(SculptEditKind.brush-strength, InspectorEditMode.set, value); } }
    }

    if root.state.has_light : VerticalBox {
        spacing: AppTheme.section_spacing;
        Text { text: root.state.light_label; }
        NudgeRow { minus_label: "LR-"; value_label: "R " + root.state.light_color_r; plus_label: "LR+"; step_down => { root.light_edit(LightEditKind.color, InspectorEditMode.nudge, 0, -0.1); } step_up => { root.light_edit(LightEditKind.color, InspectorEditMode.nudge, 0, 0.1); } }
        NudgeRow { minus_label: "LG-"; value_label: "G " + root.state.light_color_g; plus_label: "LG+"; step_down => { root.light_edit(LightEditKind.color, InspectorEditMode.nudge, 1, -0.1); } step_up => { root.light_edit(LightEditKind.color, InspectorEditMode.nudge, 1, 0.1); } }
        NudgeRow { minus_label: "LB-"; value_label: "B " + root.state.light_color_b; plus_label: "LB+"; step_down => { root.light_edit(LightEditKind.color, InspectorEditMode.nudge, 2, -0.1); } step_up => { root.light_edit(LightEditKind.color, InspectorEditMode.nudge, 2, 0.1); } }
        NudgeRow { minus_label: "Int-"; value_label: "Intensity " + root.state.light_intensity; plus_label: "Int+"; step_down => { root.light_edit(LightEditKind.intensity, InspectorEditMode.nudge, -1, -0.25); } step_up => { root.light_edit(LightEditKind.intensity, InspectorEditMode.nudge, -1, 0.25); } }
        Slider { minimum: 0; maximum: 20; step: 0.05; value: root.state.light_intensity; changed(value) => { root.light_edit(LightEditKind.intensity, InspectorEditMode.set, -1, value); } }
        NudgeRow { minus_label: "Range-"; value_label: "Range " + root.state.light_range; plus_label: "Range+"; step_down => { root.light_edit(LightEditKind.range, InspectorEditMode.nudge, -1, -0.25); } step_up => { root.light_edit(LightEditKind.range, InspectorEditMode.nudge, -1, 0.25); } }
        Slider { minimum: 0.01; maximum: 50; step: 0.05; value: root.state.light_range; changed(value) => { root.light_edit(LightEditKind.range, InspectorEditMode.set, -1, value); } }
        CheckBox { text: "Cast shadows"; checked: root.state.light_cast_shadows; toggled => { root.light_edit(LightEditKind.cast-shadows, InspectorEditMode.set, -1, self.checked ? 1.0 : 0.0); } }
        CheckBox { text: "Volumetric"; checked: root.state.light_volumetric; toggled => { root.light_edit(LightEditKind.volumetric, InspectorEditMode.set, -1, self.checked ? 1.0 : 0.0); } }
        NudgeRow { minus_label: "Vol-"; value_label: "Density " + root.state.light_volumetric_density; plus_label: "Vol+"; step_down => { root.light_edit(LightEditKind.volumetric-density, InspectorEditMode.nudge, -1, -0.05); } step_up => { root.light_edit(LightEditKind.volumetric-density, InspectorEditMode.nudge, -1, 0.05); } }
        Slider { minimum: 0; maximum: 1; step: 0.01; value: root.state.light_volumetric_density; changed(value) => { root.light_edit(LightEditKind.volumetric-density, InspectorEditMode.set, -1, value); } }
    }
}
